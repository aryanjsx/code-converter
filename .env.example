# ── LLM Provider Configuration ──────────────────────────────────────
#
# Quick start: set GEMINI_API_KEY and you're done (defaults to Gemini).
# For other providers, configure the LLM_* variables below.
#
# Restart the dev server (npm run dev) after changing this file.
# ────────────────────────────────────────────────────────────────────

# Google Gemini API key (backward-compatible shorthand)
GEMINI_API_KEY=

# Generic LLM API key (takes precedence over GEMINI_API_KEY if set)
LLM_API_KEY=

# Provider preset — determines the default base URL and model
# Options: gemini | openai | openrouter | groq | together | mistral | ollama | custom
LLM_PROVIDER=gemini

# Override the provider's default base URL
# Examples:
#   Gemini   → https://generativelanguage.googleapis.com/v1beta/openai
#   OpenAI   → https://api.openai.com/v1
#   Groq     → https://api.groq.com/openai/v1
#   Together → https://api.together.xyz/v1
#   Mistral  → https://api.mistral.ai/v1
#   OpenRouter → https://openrouter.ai/api/v1
#   Ollama   → http://localhost:11434/v1
LLM_BASE_URL=

# Override the provider's default model
# Examples:
#   Gemini   → gemini-2.5-pro
#   OpenAI   → gpt-4o
#   Groq     → llama-3.3-70b-versatile
#   Together → meta-llama/Llama-3-70b-chat-hf
#   Mistral  → mistral-large-latest
#   OpenRouter → anthropic/claude-sonnet-4
#   Ollama   → llama3
LLM_MODEL=
